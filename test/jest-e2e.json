{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\..*)\\.js$": "$1"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(@octokit|universal-user-agent|before-after-hook|eslint-plugin-unicorn)/)"
  ]
}
